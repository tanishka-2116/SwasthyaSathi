                                    <div style="font-size:24px; font-weight:800; color:#1a3a5c;">${wellnessScore !== null ? wellnessScore : '--'}</div>
                                </div>
                                <div style="background:linear-gradient(135deg, #E8F4F8, #D6EAF8); padding:12px; border-radius:14px; text-align:center;">
                                    <div style="font-size:10px; color:#888;">Total Assessments</div>
                                    <div style="font-size:24px; font-weight:800; color:#1a3a5c;">${healthHistory.length}</div>
                                </div>
                            </div>
                            <div style="display:flex; gap:10px; margin-top:12px;">
                                <button onclick="navigateTo('healthcheck')" style="flex:1; padding:8px; background:linear-gradient(135deg, #1a3a5c, #2C7DA0); color:white; border:none; border-radius:12px; cursor:pointer; font-size:12px; font-weight:600;">📝 New Assessment</button>
                                <button onclick="navigateTo('graph')" style="flex:1; padding:8px; background:#E8F4F8; color:#1a3a5c; border:none; border-radius:12px; cursor:pointer; font-size:12px; font-weight:600;">📊 View Trends</button>
                            </div>
                        </div>

                        <!-- Health Summary -->
                        <div class="card" style="padding:20px; background: rgba(255,255,255,0.92); backdrop-filter:blur(10px); border-radius:20px; box-shadow:0 8px 32px rgba(44,125,160,0.08);">
                            <h3 style="font-size:16px; color:#1a3a5c; margin-bottom:10px;">🧠 AI Health Summary</h3>
                            <p style="font-size:13px; line-height:1.5; color:#555; margin-bottom:10px;">${healthSummary}</p>
                            <div style="font-size:12px; font-weight:600; color:#1a3a5c; margin-bottom:4px;">⚡ Recommendations:</div>
                            <ul style="list-style:none; padding:0; margin:0;">
                                ${recommendations.slice(0, 3).map(rec => `<li style="font-size:11px; color:#555; padding:4px 0; border-bottom:1px solid rgba(0,0,0,0.03);">${rec}</li>`).join('')}
                            </ul>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN -->
                    <div style="display:flex; flex-direction:column; gap:20px;">

                        <!-- Health Indicators -->
                        <div class="card" style="padding:20px; background: rgba(255,255,255,0.92); backdrop-filter:blur(10px); border-radius:20px; box-shadow:0 8px 32px rgba(44,125,160,0.08);">
                            <h3 style="font-size:16px; color:#1a3a5c; margin-bottom:10px;">📊 Health Indicators</h3>
                            <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:10px;">
                                ${indicators.map(ind => `
                                    <div style="background:${ind.status === 'good' ? '#E0F4E8' : ind.status === 'warning' ? '#FFF4E0' : '#f5f5f5'}; padding:10px; border-radius:12px; text-align:center;">
                                        <div style="font-size:20px;">${ind.icon}</div>
                                        <div style="font-size:9px; color:#888; margin-top:2px;">${ind.label}</div>
                                        <div style="font-size:11px; font-weight:600; color:${ind.status === 'good' ? '#28a745' : ind.status === 'warning' ? '#f0ad4e' : '#888'};">${ind.value}</div>
                                    </div>
                                `).join('')}
                            </div>
                        </div>

                        <!-- Health Badges -->
                        ${badges.length > 0 ? `
                        <div class="card" style="padding:20px; background: rgba(255,255,255,0.92); backdrop-filter:blur(10px); border-radius:20px; box-shadow:0 8px 32px rgba(44,125,160,0.08);">
                            <h3 style="font-size:16px; color:#1a3a5c; margin-bottom:10px;">🏆 Achievements</h3>
                            <div style="display:flex; flex-wrap:wrap; gap:8px;">
                                ${badges.map(b => `
                                    <span style="background:linear-gradient(135deg, #E8F4F8, #D6EAF8); padding:4px 12px; border-radius:20px; font-size:11px; font-weight:500; color:#1a3a5c; display:flex; align-items:center; gap:4px;">
                                        ${b.icon} ${b.label}
                                    </span>
                                `).join('')}
                            </div>
                        </div>
                        ` : ''}

                        <!-- Recent Activity -->
                        <div class="card" style="padding:20px; background: rgba(255,255,255,0.92); backdrop-filter:blur(10px); border-radius:20px; box-shadow:0 8px 32px rgba(44,125,160,0.08); flex:1;">
                            <h3 style="font-size:16px; color:#1a3a5c; margin-bottom:10px;">📋 Recent Activity</h3>
                            ${activityHtml}
                        </div>
                    </div>

                </div>
            `;
        }

        // ===== RENDER: HEALTH CHECK =====
        function renderHealthCheck() {
            document.getElementById('mainContent').innerHTML = `
                <div class="card lab-upload-card">
                    <h3 class="card-title">Upload Blood Report</h3>
                    <p style="font-size: 11px; color: #666; margin-bottom: 10px;">Upload your blood test report (PDF or Image) to automatically extract Blood Sugar and Hemoglobin values</p>
                    <input type="file" id="labReportFile" accept=".pdf,.jpg,.png,.jpeg" style="margin-bottom: 10px;">
                    <button class="btn-secondary" onclick="uploadLabReport()" style="width: auto; padding: 6px 15px;">Upload & Extract Values</button>
                    <div id="extractedData" style="margin-top: 10px; font-size: 12px;"></div>
                </div>
                <div class="card">
                    <h3 class="card-title">Complete Health Risk Assessment</h3>
                    <p style="margin-bottom: 10px; font-size: 11px; color: #666;">Fill the details below for analysis</p>
                    <div class="form-super-compact">
                        <div class="form-group"><label>Age</label><input type="text" id="age" placeholder="e.g., 35"></div>
                        <div class="form-group"><label>Height (cm)</label><input type="text" id="height" placeholder="e.g., 170"></div>
                        <div class="form-group"><label>Weight (kg)</label><input type="text" id="weight" placeholder="e.g., 68"></div>
                        <div class="form-group"><label>Gender</label><select id="gender"><option>Male</option><option>Female</option><option>Other</option></select></div>
                        <div class="form-group"><label>Smoking</label><select id="smoking"><option>No</option><option>Yes</option><option>Occasionally</option></select></div>
                        <div class="form-group"><label>Tobacco</label><select id="tobacco"><option>No</option><option>Yes</option><option>Occasionally</option></select></div>
                        <div class="form-group"><label>Alcohol</label><select id="alcohol"><option>No</option><option>Occasionally</option><option>Weekly</option><option>Daily</option></select></div>
                        <div class="form-group"><label>Diet</label><select id="diet"><option>Balanced</option><option>Somewhat Healthy</option><option>Unhealthy</option></select></div>
                        <div class="form-group"><label>Exercise</label><select id="exercise"><option>Daily</option><option>Weekly</option><option>Rarely</option><option>Never</option></select></div>
                        <div class="form-group"><label>Sleep</label><input type="text" id="sleep" placeholder="7-8 hrs"></div>
                        <div class="form-group"><label>Diabetes</label><select id="diabetes"><option>No</option><option>Yes</option><option>Prediabetic</option></select></div>
                        <div class="form-group"><label>Heart History</label><select id="heart"><option>No</option><option>Yes</option></select></div>
                        <div class="form-group full-width"><label>Stress Level</label><select id="stress"><option>Low</option><option>Medium</option><option>High</option></select></div>
                    </div>
                    <button class="btn-primary" style="margin-top: 12px;" onclick="calculateRisk()">Analyze My Health Risk</button>
                </div>
                <div id="resultArea"></div>
            `;
        }

        // ===== CALCULATE RISK =====
        async function calculateRisk() {
            const age = document.getElementById('age').value;
            const height = document.getElementById('height').value;
            const weight = document.getElementById('weight').value;
            const smoking = document.getElementById('smoking').value;
            const tobacco = document.getElementById('tobacco').value;
            const alcohol = document.getElementById('alcohol').value;
            const diet = document.getElementById('diet').value;
            const exercise = document.getElementById('exercise').value;
            const diabetes = document.getElementById('diabetes').value;
            const heart = document.getElementById('heart').value;
            const stress = document.getElementById('stress').value;
            const sleep = document.getElementById('sleep').value;
            const gender = document.getElementById('gender').value;
            const bloodSugar = extractedLabValues.bloodSugar || 0;
            const hemoglobin = extractedLabValues.hemoglobin || 0;

            if (!age || !height || !weight) { alert("Fill Age, Height, Weight"); return; }
            if (isNaN(age) || age <= 0 || age > 120) { alert("Valid age 1-120"); return; }
            if (isNaN(height) || height <= 0 || height > 300) { alert("Valid height 1-300 cm"); return; }
            if (isNaN(weight) || weight <= 0 || weight > 500) { alert("Valid weight 1-500 kg"); return; }

            const heightM = height / 100;
            const bmi = (weight / (heightM * heightM)).toFixed(1);
            showToast("Analyzing your health risk...", 'success');

            try {
                const response = await fetch('api.php?action=calculate-risk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        age: parseInt(age), bmi: parseFloat(bmi), smoking, tobacco, alcohol, diet, exercise, diabetes, heart, stress, gender,
                        bloodSugar: bloodSugar, hemoglobin: hemoglobin,
                        userEmail: currentUserEmail,
                        userName: currentUserName
                    })
                });
                const data = await response.json();
                if (data.success) {
                    const today = new Date();
                    const year = today.getFullYear();
                    const month = String(today.getMonth() + 1).padStart(2, '0');
                    const day = String(today.getDate()).padStart(2, '0');
                    const localDate = year + '-' + month + '-' + day;

                    const newAssessment = {
                        date: localDate,
                        bmi: parseFloat(bmi), riskScore: data.riskScore, riskLevel: data.riskLevel, wellnessScore: data.wellnessScore, age: age
                    };

                    await saveAssessmentToDB(newAssessment);
                    await loadAssessmentsFromDB();

                    wellnessScore = data.wellnessScore; riskLevel = data.riskLevel; latestBmi = bmi;

                    let riskClass = data.riskLevel === 'High' ? 'risk-high' : data.riskLevel === 'Medium' ? 'risk-medium' : 'risk-low';
                    let recHtml = data.recommendations.map(rec => `<li>${rec}</li>`).join('');
                    let schemesHtml = data.schemes.map(scheme => `<div class="scheme-card" onclick="window.open('${scheme.official_link}', '_blank')" style="cursor:pointer;"><h4 style="font-size:13px;">${scheme.name}</h4><p style="font-size:10px;">${scheme.benefits}</p><small style="font-size:9px;">Eligibility: ${scheme.eligibility}</small></div>`).join('');

                    let emailStatusHtml = '';
                    if (data.emailSent) {
                        emailStatusHtml = '<div style="background: #d4edda; color: #155724; padding: 10px; border-radius: 8px; margin: 10px 0; font-size: 12px;">✅ Report sent to your email: ' + currentUserEmail + '</div>';
                    } else if (data.emailError) {
                        emailStatusHtml = '<div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 8px; margin: 10px 0; font-size: 12px;">⚠️ Email could not be sent. But your report is saved here.</div>';
                    }

                    let labInterpretationHtml = '';
                    if (bloodSugar > 0 || hemoglobin > 0) {
                        let bsStatus = bloodSugar > 125 ? 'High' : (bloodSugar > 100 ? 'Borderline' : 'Normal');
                        let hbStatus = hemoglobin < 12 ? 'Low' : 'Normal';
                        let interpretation = '';
                        if (bloodSugar > 100) interpretation += 'Blood sugar is elevated. ';
                        if (hemoglobin < 12 && hemoglobin > 0) interpretation += 'Hemoglobin is low. ';
                        if (interpretation === '') interpretation = 'All lab values are within normal range.';

                        labInterpretationHtml = `
                            <div style="background: linear-gradient(135deg, #E8F4F8, #D9EAF3); padding: 12px; border-radius: 12px; margin: 12px 0;">
                                <h4 style="color: #1a3a5c; margin-bottom: 8px;">Extracted Lab Report Values</h4>
                                <div class="form-super-compact">
                                    <div><strong>Blood Sugar:</strong> ${bloodSugar} mg/dL (${bsStatus})</div>
                                    <div><strong>Hemoglobin:</strong> ${hemoglobin} g/dL (${hbStatus})</div>
                                </div>
                                <p style="font-size: 11px; margin-top: 8px; background: white; padding: 6px; border-radius: 8px;">Interpretation: ${interpretation}</p>
                            </div>
                        `;
                    }

                    currentPDFContent = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>SwasthyaSathi Health Report</title><style>*{margin:0;padding:0;box-sizing:border-box;}body{font-family:'Segoe UI',Arial,sans-serif;padding:15px;max-width:100%;color:#333;line-height:1.3;}h1{color:#1a3a5c;text-align:center;font-size:20px;margin-bottom:5px;}.report-date{text-align:center;color:#666;font-size:10px;margin-bottom:10px;}.user-info{background:#E8F4F8;padding:8px;border-radius:6px;margin-bottom:10px;font-size:11px;}.risk-box{padding:8px;border-radius:6px;margin-bottom:10px;text-align:center;}.risk-High{background:#FCE4E0;border-left:4px solid #E8A598;}.risk-Medium{background:#FFF4E0;border-left:4px solid #F0D08C;}.risk-Low{background:#E0F4E8;border-left:4px solid #A8D8EA;}.section{background:#f5f5f5;padding:8px;border-radius:6px;margin-bottom:8px;}h3{color:#1a3a5c;font-size:12px;margin-bottom:5px;}p{font-size:10px;margin:3px 0;}ul{padding-left:20px;margin:5px 0;}li{font-size:10px;margin:2px 0;}.scheme-item{background:#E8F4F8;padding:6px;border-radius:6px;margin:5px 0;}.footer{text-align:center;font-size:9px;color:#999;margin-top:10px;border-top:1px solid #ddd;padding-top:5px;}.two-column{display:flex;gap:10px;margin-bottom:8px;}.two-column>div{flex:1;background:#f5f5f5;padding:8px;border-radius:6px;}@media print{body{padding:0;}.no-break{break-inside:avoid;page-break-inside:avoid;}}</style></head><body>
                    <h1>SwasthyaSathi Health Report</h1><div class="report-date">Generated: ${new Date().toLocaleString()}</div>
                    <div class="user-info"><strong>${currentUserName}</strong> | ${currentUserEmail}</div>
                    <div class="risk-box risk-${data.riskLevel} no-break"><strong>Risk Level: ${data.riskLevel}</strong> | Score: ${data.riskScore}/100 | Wellness: ${data.wellnessScore}/100</div>
                    <div class="two-column no-break"><div><strong>Age:</strong> ${age} yrs<br><strong>BMI:</strong> ${bmi}</div><div><strong>Sleep:</strong> ${sleep || 'N/A'} hrs<br><strong>Stress:</strong> ${stress}</div></div>
                    ${(bloodSugar > 0 || hemoglobin > 0) ? `<div class="section no-break"><strong>📊 Lab Values:</strong> ${bloodSugar > 0 ? `Blood Sugar: ${bloodSugar} mg/dL` : ''} ${hemoglobin > 0 ? `| Hemoglobin: ${hemoglobin} g/dL` : ''}</div>` : ''}
                    <div class="section no-break"><strong>📋 Recommendations:</strong><ul>${data.recommendations.slice(0, 4).map(rec => `<li>${rec.length > 60 ? rec.substring(0, 60) + '...' : rec}</li>`).join('')}</ul>${data.recommendations.length > 4 ? '<p style="font-size:9px;">+ ' + (data.recommendations.length - 4) + ' more recommendations in portal</p>' : ''}</div>
                    <div class="section no-break"><strong>🏛️ Government Schemes:</strong>${data.schemes.slice(0, 2).map(scheme => `<div class="scheme-item"><strong>${scheme.name}</strong><br>${scheme.benefits.substring(0, 80)}${scheme.benefits.length > 80 ? '...' : ''}</div>`).join('')}${data.schemes.length > 2 ? '<p style="font-size:9px;">+ ' + (data.schemes.length - 2) + ' more schemes in portal</p>' : ''}</div>
                    <div class="footer">SwasthyaSathi — AI-Powered Preventive Healthcare Platform | http://swasthya.kesug.com</div>
                </body></html>`;

                    document.getElementById('resultArea').innerHTML = `
                        <div class="card">
                            <h3 class="card-title">Your Health Report</h3>
                            ${emailStatusHtml}
                            <div class="${riskClass}"><h3 style="font-size: 14px;">Risk Level: ${data.riskLevel}</h3><p style="font-size: 11px;">Risk Score: ${data.riskScore}/100 | Wellness Score: ${data.wellnessScore}/100</p></div>
                            ${labInterpretationHtml}
                            <h4 style="font-size: 13px; margin: 8px 0 5px 0;">Body Metrics</h4>
                            <p style="font-size: 11px;"><strong>Age:</strong> ${age} | <strong>Height:</strong> ${height} cm | <strong>Weight:</strong> ${weight} kg | <strong>BMI:</strong> ${bmi}</p>
                            <p style="font-size: 11px;"><strong>Sleep:</strong> ${sleep || 'Not specified'} hrs | <strong>Stress:</strong> ${stress}</p>
                            <h4 style="font-size: 13px; margin: 8px 0 5px 0;">Recommendations</h4>
                            <ul class="recommendation-list">${recHtml}</ul>
                            <h4 style="font-size: 13px; margin: 8px 0 5px 0;">Government Schemes</h4>
                            ${schemesHtml}
                            <div class="flex-buttons">
                                <button class="btn-secondary" onclick="renderHealthCheck()">New Assessment</button>
                                <button class="btn-primary" onclick="navigateTo('wellness')">Wellness Score</button>
                                <button class="btn-primary" onclick="navigateTo('graph')">Health Graph</button>
                                <button class="btn-primary btn-pdf" onclick="exportPDF()">Download PDF Report</button>
                            </div>
                        </div>
                    `;
                    extractedLabValues = { bloodSugar: 0, hemoglobin: 0 };
                }
            } catch(err) { alert("Error: " + err.message); }
        }

        function exportPDF() {
            if (!currentPDFContent) { alert("Complete a health assessment first."); return; }
            const pdfWindow = window.open();
            pdfWindow.document.write(currentPDFContent);
            pdfWindow.document.close();
            pdfWindow.print();
        }

        // ===== RENDER: WELLNESS SCORE =====
        function renderWellnessScore() {
            let scoreHtml = wellnessScore !== null ? `
                <div class="score-circle"><div class="score-number">${wellnessScore}</div><div>/100</div></div>
                <div style="text-align:center;"><p style="font-size: 13px; font-weight: 700;">${wellnessScore >= 70 ? 'Excellent. Keep it up.' : wellnessScore >= 40 ? 'Good progress. Keep improving.' : 'Needs attention. Consult a doctor.'}</p></div>
            ` : '<p style="text-align:center; padding: 20px;">Complete a health assessment first</p>';
            document.getElementById('mainContent').innerHTML = `
                <div class="card"><h3 class="card-title">Your Wellness Score</h3>${scoreHtml}</div>
                <div class="card"><h3 class="card-title">Score Breakdown</h3><div class="stats-grid"><div class="stat-card"><div class="stat-number">${riskLevel !== null ? riskLevel : '--'}</div><div class="stat-label">Risk Level</div></div><div class="stat-card"><div class="stat-number">${latestBmi !== null ? latestBmi : '--'}</div><div class="stat-label">Latest BMI</div></div></div><button class="btn-primary" onclick="navigateTo('healthcheck')">Take New Assessment</button></div>
            `;
        }

        // ===== RENDER: GRAPH =====
        function renderGraph() {
            document.getElementById('mainContent').innerHTML = `
                <div class="card"><h3 class="card-title">Health Trends Graph</h3><div style="margin-bottom: 8px; font-size: 11px;"><span><span class="legend-bmi"></span> BMI (Left Axis)</span>&nbsp;&nbsp;&nbsp;<span><span class="legend-risk"></span> Risk Score (Right Axis)</span></div><div class="graph-container"><canvas id="trendChart"></canvas></div><div class="graph-interpretation" id="graphInterpretation"></div></div>
                <div class="card"><h3 class="card-title">Assessment History</h3><div id="historyList"></div></div>
            `;
            if (healthHistory.length > 0) {
                const labels = healthHistory.map(h => h.date);
                const bmiData = healthHistory.map(h => h.bmi);
                const riskData = healthHistory.map(h => h.riskScore);
                if (chartInstance) chartInstance.destroy();
                const ctx = document.getElementById('trendChart').getContext('2d');
                chartInstance = new Chart(ctx, {
                    type: 'line',
                    data: { labels, datasets: [{ label: 'BMI', data: bmiData, borderColor: '#2C7DA0', fill: true, tension: 0.3, yAxisID: 'y' }, { label: 'Risk Score', data: riskData, borderColor: '#DC143C', fill: true, tension: 0.3, yAxisID: 'y1' }] },
                    options: { responsive: true, scales: { y: { title: { display: true, text: 'BMI' }, min: 10, max: 40 }, y1: { position: 'right', title: { display: true, text: 'Risk Score' }, grid: { drawOnChartArea: false }, min: 0, max: 100 } } }
                });
                const latestRisk = riskData[riskData.length - 1];
                document.getElementById('graphInterpretation').innerHTML = `<div class="interpretation-title">Dual Trend Analysis</div><p><strong>Recommendation:</strong> ${latestRisk <= 20 ? 'Low risk. Maintain healthy habits.' : latestRisk <= 50 ? 'Moderate risk. Follow recommendations.' : 'High risk. Consult a doctor.'}</p>`;
                let historyHtml = '';
                for (let i = 0; i < healthHistory.length; i++) {
                    const h = healthHistory[i];
                    historyHtml += `<div class="profile-row"><div class="profile-label">${h.date}</div><div>BMI: ${h.bmi} | Risk: ${h.riskScore} | Level: ${h.riskLevel}</div><button class="delete-btn" onclick="deleteAssessment(${i})">Delete</button></div>`;
                }
                document.getElementById('historyList').innerHTML = historyHtml;
            } else {
                document.getElementById('historyList').innerHTML = '<p style="text-align:center; padding:20px;">No assessments yet.</p>';
                document.getElementById('graphInterpretation').innerHTML = '<p style="text-align:center;">Complete an assessment to see trends.</p>';
            }
        }

        // ===== LOGOUT =====
        function logout() {
            currentUserId = null; currentUserName = null; currentUserEmail = null; currentRegisteredDate = null;
            healthHistory = []; wellnessScore = null; riskLevel = null; latestBmi = null;
            extractedLabValues = { bloodSugar: 0, hemoglobin: 0 };
            document.getElementById('dashboardScreen').classList.add('hidden');
            document.getElementById('loginScreen').classList.remove('hidden');
            document.getElementById('userNameInput').value = '';
            document.getElementById('userEmailInput').value = '';
            showToast('Logged out successfully');
        }

        // ===== INIT =====
        setupNavigation();
    </script>
</body>
</html>
