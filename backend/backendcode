    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
)");

$action = $_GET['action'] ?? '';

// Save user (with registration date)
if ($action == 'save-user') {
    $data = json_decode(file_get_contents("php://input"), true);
    $name = trim($data['name'] ?? '');
    $email = trim($data['email'] ?? '');
    
    if (empty($name) || empty($email)) {
        echo json_encode(["success" => false, "error" => "Name and email required"]);
        exit;
    }
    
    // Check if user already exists
    $stmt = $conn->prepare("SELECT id, name, registered_date FROM users WHERE email = ?");
    $stmt->bind_param("s", $email);
    $stmt->execute();
    $result = $stmt->get_result();
    
    if ($result && $result->num_rows > 0) {
        $user = $result->fetch_assoc();
        echo json_encode([
            "success" => true, 
            "userId" => $user['id'], 
            "name" => $user['name'],
            "registeredDate" => $user['registered_date'],
            "isNew" => false
        ]);
    } else {
        // New user - store registration date as today (IST)
        $registeredDate = date('Y-m-d');
        $stmt = $conn->prepare("INSERT INTO users (name, email, registered_date) VALUES (?, ?, ?)");
        $stmt->bind_param("sss", $name, $email, $registeredDate);
        $stmt->execute();
        $userId = $stmt->insert_id;
        echo json_encode([
            "success" => true, 
            "userId" => $userId, 
            "name" => $name,
            "registeredDate" => $registeredDate,
            "isNew" => true
        ]);
    }
    exit;
}

