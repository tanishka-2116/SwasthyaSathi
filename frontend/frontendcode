        function extractLabValuesFromText(text) {
            let bloodSugar = 0, hemoglobin = 0;
            const sugarPatterns = [
                /(?:blood sugar|blood glucose|glucose|sugar)[:\s]*(\d{2,3})/i,
                /(?:fbg|ppbs|rbs)[:\s]*(\d{2,3})/i,
                /glucose[:\s]*(\d{2,3})/i,
                /sugar[:\s]*(\d{2,3})/i
            ];
            for (let pattern of sugarPatterns) {
                const match = text.match(pattern);
                if (match && match[1]) {
                    bloodSugar = parseInt(match[1]);
                    if (bloodSugar >= 50 && bloodSugar <= 300) break;
                    else bloodSugar = 0;
                }
            }
            if (bloodSugar === 0) {
                const possibleSugar = text.match(/\b(7[0-9]|8[0-9]|9[0-9]|1[0-4][0-9]|150)\b/g);
                if (possibleSugar && possibleSugar.length > 0) {
                    for (let val of possibleSugar) {
                        const num = parseInt(val);
                        if (num >= 70 && num <= 150) {
                            bloodSugar = num;
                            break;
                        }
                    }
                }
            }
            const hbPatterns = [
                /(?:hemoglobin|haemoglobin|hb|hgb)[:\s]*(\d{1,2}\.?\d?)/i,
                /(?:hb|hgb)[:\s]*(\d{1,2}\.?\d?)/i,
                /(\d{1,2}\.?\d?)\s*g\/dL/i
            ];
            for (let pattern of hbPatterns) {
                const match = text.match(pattern);
                if (match && match[1]) {
                    hemoglobin = parseFloat(match[1]);
                    if (hemoglobin >= 8 && hemoglobin <= 18) break;
                    else hemoglobin = 0;
                }
            }
            if (hemoglobin === 0) {
                const possibleHb = text.match(/\b(1[0-6](?:\.\d)?)\b/g);
                if (possibleHb && possibleHb.length > 0) {
                    for (let val of possibleHb) {
                        const num = parseFloat(val);
                        if (num >= 10 && num <= 16) {
                            hemoglobin = num;
                            break;
                        }
                    }
                }
            }
            if (bloodSugar > 0 || hemoglobin > 0) {
                extractedLabValues = { bloodSugar, hemoglobin };
                let bsText = bloodSugar > 125 ? 'High (Diabetes risk)' : bloodSugar > 100 ? 'Borderline (Pre-diabetes)' : 'Normal';
                let hbText = hemoglobin < 12 && hemoglobin > 0 ? 'Low (Anemia risk)' : hemoglobin >= 12 ? 'Normal' : '';
                let interpretation = '';
                if (bloodSugar > 100) interpretation += 'Blood sugar is elevated. ';
                if (hemoglobin < 12 && hemoglobin > 0) interpretation += 'Hemoglobin is low. ';
                if (interpretation === '' && (bloodSugar > 0 || hemoglobin > 0)) interpretation = 'All lab values are within normal range.';
                document.getElementById('extractedData').innerHTML = `
                    <div style="background:rgba(46,125,50,0.1);padding:12px;border-radius:12px;margin-top:10px;">
                        <p style="font-weight:bold;color:#1a3a5c;margin-bottom:10px;">Extracted Values from Your Blood Report:</p>
                        <div class="form-super-compact">
                            <div><strong>Blood Sugar:</strong> ${bloodSugar > 0 ? bloodSugar + ' mg/dL' : 'Not detected'} ${bloodSugar > 0 ? `<br><span class="lab-${bloodSugar > 125 ? 'high' : (bloodSugar > 100 ? 'borderline' : 'normal')}">${bsText}</span>` : ''}</div>
                            <div><strong>Hemoglobin:</strong> ${hemoglobin > 0 ? hemoglobin + ' g/dL' : 'Not detected'} ${hemoglobin > 0 ? `<br><span class="lab-${hemoglobin < 12 ? 'high' : 'normal'}">${hbText}</span>` : ''}</div>
                        </div>
                        <p style="margin-top:8px;font-size:11px;background:white;padding:6px;border-radius:8px;">Interpretation: ${interpretation}</p>
                    </div>
                `;
                showToast("Lab values extracted successfully", 'success');
            } else {
                showToast("Could not find values. Please enter manually.", 'error');
                showManualEntry();
            }
        }

        function showManualEntry() {
            document.getElementById('extractedData').innerHTML = `
                <div style="background:rgba(97,165,194,0.15);padding:12px;border-radius:12px;margin-top:10px;">
