// ✅ FIXED: Save assessment with correct timezone and bind params
// ============================================================
if ($action == 'save-assessment') {
    $data = json_decode(file_get_contents("php://input"), true);
    
    $user_id = $data['userId'] ?? 0;
    $age = $data['age'] ?? 0;
    $bmi = $data['bmi'] ?? 0;
    $riskScore = $data['riskScore'] ?? 0;
    $riskLevel = $data['riskLevel'] ?? '';
    $wellnessScore = $data['wellnessScore'] ?? 0;
    
    // ✅ Set MySQL session timezone to IST
    $conn->query("SET time_zone = '+05:30'");
    
    // ✅ Include assessment_date with NOW()
    $stmt = $conn->prepare("INSERT INTO assessments (user_id, age, bmi, risk_score, risk_level, wellness_score, assessment_date) VALUES (?, ?, ?, ?, ?, ?, NOW())");
    
    // ✅ Correct bind_param: i=integer, d=decimal, s=string
    // Parameters: user_id(int), age(int), bmi(decimal), riskScore(int), riskLevel(string), wellnessScore(int)
    $stmt->bind_param("iidisi", $user_id, $age, $bmi, $riskScore, $riskLevel, $wellnessScore);
    
    if ($stmt->execute()) {
        $new_id = $conn->insert_id;
        echo json_encode([
            "success" => true, 
            "id" => $new_id,
            "message" => "Assessment saved successfully"
        ]);
    } else {
        echo json_encode([
            "success" => false, 
            "error" => $stmt->error
        ]);
    }
    exit;
}

// Get all assessments for a user
if ($action == 'get-assessments') {
    $user_id = isset($_GET['userId']) ? intval($_GET['userId']) : 0;
    
    // ✅ Set timezone for accurate date display
    $conn->query("SET time_zone = '+05:30'");
    
    $stmt = $conn->prepare("SELECT id, age, bmi, risk_score, risk_level, wellness_score, assessment_date FROM assessments WHERE user_id = ? ORDER BY assessment_date DESC");
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $result = $stmt->get_result();
    
    $assessments = [];
    while ($row = $result->fetch_assoc()) {
        $assessments[] = [
            'id' => $row['id'],
            'age' => $row['age'],
            'bmi' => $row['bmi'],
            'risk_score' => $row['risk_score'],
            'risk_level' => $row['risk_level'],
            'wellness_score' => $row['wellness_score'],
            'assessment_date' => $row['assessment_date']
        ];
    }
    echo json_encode($assessments);
    exit;
}

// Delete assessment
if ($action == 'delete-assessment') {
